  "authors": [
    "GT3CH1",
    "Starmism"
  ],
  "contact": {
    "homepage": "https://github.com/gavinsmod/gavinsextensiblemod",
    "sources": "https://github.com/gavinsmod/gavinsextensiblemod"
  },
  "license": "MIT",
  "icon": "assets/gavinsmod/gemclient-logo.png",
